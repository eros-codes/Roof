# .gitignore — Roof project (Node, frontend, tooling)
# See https://git-scm.com/docs/gitignore for pattern reference

# Node modules
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Runtime files
pids/
*.pid
*.seed

# Build / output
dist/
build/
out/
public/build/
.cache/
.parcel-cache/

# Next.js / Vercel
.next/
.vercel/
.now/

# Coverage
coverage/
.nyc_output/

# Test and temporary folders
.jest/
test-results/
reports/

# TypeScript
*.tsbuildinfo

# Environment / secret files
.env
.env.*.local
prisma/.env

# Database files
*.sqlite
*.sqlite3
*.db
*.db-journal

# Yarn v2/v3
.yarn/*
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
.pnp.*

# IDE / editor config
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS generated files
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Editor temporary files
*~
*.swp
*.swo
.#*

# Certificates, keys
*.pem
*.key
*.crt

# Archives
*.tgz

# Temporary, cache, uploads
tmp/
temp/
uploads/
public/uploads/

# Misc
*.log.*

seed.js

# Ignore product images but keep the folder with a tracked .gitkeep
/public/assets/images/products/**
!/public/assets/images/products/.gitkeep