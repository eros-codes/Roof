DATABASE_URL="postgresql://roof_user:password@localhost:5432/roof"

# Server port
PORT=4000

# Frontend origins
CLIENT_ORIGIN="http://localhost:3000"
ADMIN_ORIGIN="http://localhost:3001"

# Comma-separated allowed origins (used by CORS)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# JWT settings
JWT_SECRET="change-this-to-a-random-secret"
JWT_EXPIRES_IN="7d"

# If your app is deployed behind a reverse proxy (nginx, Cloudflare, Heroku,
# etc.) set TRUST_PROXY to the appropriate value (e.g. '1') so Express can
# correctly detect the originating client IP for rate limiting and logging.
# Example: TRUST_PROXY=1
TRUST_PROXY=

# Admin panel host name. Use a dedicated subdomain for the admin UI.
# Example for local development:
# ADMIN_HOST=admin.localhost
# Example for production:
# ADMIN_HOST=admin.roof.ir
ADMIN_HOST=

# Initial admin account (used by prisma seed)
ADMIN_USERNAME="your_username"
ADMIN_PASSWORD="your_password"
