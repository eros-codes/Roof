DATABASE_URL="file:./prisma/dev.db"

# Server port
PORT=4000

# Frontend origins
CLIENT_ORIGIN="http://localhost:3000"
ADMIN_ORIGIN="http://localhost:3001"

# Admin proxy port
ADMIN_PORT=3001

# API origin (where backend is served)
API_ORIGIN="http://localhost:4000"

# Comma-separated allowed origins (used by CORS)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Optional: if set, injected into admin UI as window.__API_ORIGIN__
ADMIN_INJECT_API_ORIGIN=""

# JWT settings
JWT_SECRET="change-this-to-a-random-secret"
JWT_EXPIRES_IN="7d"

# Initial admin account (used by prisma seed)
ADMIN_USERNAME="your_username"
ADMIN_PASSWORD="your_password"
